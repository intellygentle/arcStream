                      <span className="flex items-center gap-1 text-[#00C8B3] font-medium">
                        <DollarSign size={14} />
                        {v.pricePerChunk.toFixed(6)} USDC
                      </span>
                      <span className="text-gray-500">/ {v.chunkDuration} min</span>
