                  value={form.chunkValue} 
                  onChange={handleChange} 
                  min="1"
                  disabled={submitting}
                  className="flex-1 p-3 bg-[#1F1A31] border border-[#3D3458] rounded-xl text-white outline-none focus:ring-2 focus:ring-[#8656EF] disabled:opacity-50 transition" 
                />
                <select 
